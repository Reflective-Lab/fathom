{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fathom",
  "version": "0.1.0",
  "identifier": "se.reflective.fathom",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "devUrl": "http://127.0.0.1:5110",
    "beforeBuildCommand": "bun run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fathom",
        "width": 1220,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
